# =============================================================================
# Fire Intelligence Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fire_intelligence

# -----------------------------------------------------------------------------
# Security / JWT
# -----------------------------------------------------------------------------
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Object Storage
# -----------------------------------------------------------------------------
# Supported providers: local, supabase
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./data/storage

# Supabase Storage (only when STORAGE_PROVIDER=supabase)
SUPABASE_URL=
SUPABASE_KEY=

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Model identifiers
LLM_MODEL=qwen-plus
VISION_MODEL=qwen-vl-plus
EMBEDDING_MODEL=text-embedding-v3
RERANKER_MODEL=gte-rerank

# -----------------------------------------------------------------------------
# RAG / Vector Store (Chroma)
# -----------------------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=fire_knowledge

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# File Uploads
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=500
